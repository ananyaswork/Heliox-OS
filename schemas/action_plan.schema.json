{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActionPlan",
  "description": "A structured plan of system actions generated by the Planner LLM",
  "type": "object",
  "required": ["actions", "explanation"],
  "properties": {
    "explanation": {
      "type": "string",
      "description": "Human-readable explanation of what the plan will do"
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/Action" },
      "minItems": 1
    }
  },
  "$defs": {
    "Action": {
      "type": "object",
      "required": ["action_type", "target", "parameters"],
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "file_read", "file_write", "file_delete", "file_move", "file_copy", "file_list", "file_search", "directory_summary",
            "package_install", "package_remove", "package_update", "package_search",
            "service_start", "service_stop", "service_restart", "service_enable", "service_disable", "service_status",
            "gnome_setting_read", "gnome_setting_write",
            "dbus_call",
            "shell_command"
          ]
        },
        "target": {
          "type": "string",
          "description": "Primary resource identifier (file path, package name, service name, etc.)"
        },
        "parameters": {
          "type": "object",
          "description": "Action-type-specific parameters"
        },
        "requires_root": { "type": "boolean", "default": false },
        "destructive": { "type": "boolean", "default": false },
        "reversible": { "type": "boolean", "default": true },
        "rollback_action": {
          "oneOf": [
            { "$ref": "#/$defs/Action" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
